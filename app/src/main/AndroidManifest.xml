<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".AegisInputApplication"
        android:allowBackup="false"
        android:icon="@drawable/ic_aegis_input"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AegisInput">

        <activity
            android:name="com.aegisinput.app.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.aegisinput.app.SettingsActivity"
            android:exported="true"
            android:label="@string/settings_title" />

        <service
            android:name="com.aegisinput.app.AegisInputService"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>
